generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  clerkUserId     String           @unique
  email           String           @unique
  name            String?
  imageUrl        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bio             String?
  experience      Int?
  skills          String[]
  industry        String?
  assessmeants    Assessment[]
  coverLetter     CoverLetter[]
  resume          Resume?
  industryInsight IndustryInsight? @relation(fields: [industry], references: [industry])
}

model Assessment {
  id             String   @id @default(cuid())
  userId         String
  createdAt      DateTime @default(now())
  category       String
  improvementTip String?
  updatedAt      DateTime @updatedAt
  quizeScore     Float
  questions      Json[]
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Resume {
  id        String   @id @default(cuid())
  userId    String   @unique
  atsScore  Float
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  feedBack  String?
  user      User     @relation(fields: [userId], references: [id])
}

model CoverLetter {
  id             String   @id @default(cuid())
  userId         String
  content        String
  companyName    String
  createdAt      DateTime @default(now())
  jobDescription String?
  jobTitle       String
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}

model IndustryInsight {
  id                String        @id @default(cuid())
  industry          String        @unique
  growthRate        Float
  demandLevel       DemandLevel
  topSkills         String[]
  keyTrends         String[]
  recommendedSkills String[]
  lastUpdated       DateTime      @default(now())
  nextUpdate        DateTime
  salaryRanges      Json[]
  marketOutlook     MarketOutLook
  users             User[]

  @@index([industry])
}

enum DemandLevel {
  High
  Medium
  Low
}

enum MarketOutLook {
  Positive
  Neutral
  Negative
}
